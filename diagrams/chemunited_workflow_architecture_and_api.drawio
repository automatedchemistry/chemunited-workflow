  <diagram id="api-endpoints" name="API Endpoints">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="api-title" value="FastAPI Endpoint Surface" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=28;fontStyle=1;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="430" y="25" width="740" height="40" as="geometry" />
        </mxCell>
        <mxCell id="api-subtitle" value="Routes included by chemunited_workflow.api.create_api(project_dir, processes, configs, main_parameter_class, enable_builder)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontColor=#4b5563;" vertex="1" parent="1">
          <mxGeometry x="250" y="70" width="1100" height="30" as="geometry" />
        </mxCell>

        <mxCell id="api-root" value="Root and Docs&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;GET / - redirects to /docs&lt;br&gt;GET /docs - Swagger UI&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#6b7280;fontColor=#374151;align=left;spacingLeft=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="125" width="460" height="80" as="geometry" />
        </mxCell>

        <mxCell id="proc-box" value="Processes Router&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;GET /processes/&lt;br&gt;GET /processes/{name}/schema&lt;br&gt;GET /processes/{name}/source&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;align=left;spacingLeft=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="250" width="310" height="145" as="geometry" />
        </mxCell>
        <mxCell id="snap-box" value="Snapshots Router&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;GET /snapshots/&lt;br&gt;GET /snapshots/{filename}&lt;br&gt;POST /snapshots/ (builder mode)&lt;br&gt;DELETE /snapshots/{filename} (builder mode)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfccb;strokeColor=#65a30d;fontColor=#365314;align=left;spacingLeft=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="445" y="250" width="330" height="160" as="geometry" />
        </mxCell>
        <mxCell id="run-box" value="Run Router&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;POST /run/&lt;br&gt;GET /run/active&lt;br&gt;GET /run/{run_id}/status&lt;br&gt;GET /run/{run_id}/report&lt;br&gt;GET /run/{run_id}/stream (SSE)&lt;br&gt;GET /run/pool&lt;br&gt;DELETE /run/{run_id}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#78350f;align=left;spacingLeft=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="250" width="330" height="235" as="geometry" />
        </mxCell>
        <mxCell id="logs-box" value="Logs Router&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;GET /logs/&lt;br&gt;GET /logs/search?query=...&amp;amp;max_results=50&lt;br&gt;GET /logs/{filename}?tail=N&lt;br&gt;POST /logs/{filename}/archive&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#7f1d1d;align=left;spacingLeft=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1235" y="250" width="310" height="165" as="geometry" />
        </mxCell>
        <mxCell id="components-box" value="Components Router&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;GET /components/&lt;br&gt;GET /components/ping?timeout=2.0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0d9488;fontColor=#134e4a;align=left;spacingLeft=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="520" width="310" height="120" as="geometry" />
        </mxCell>
        <mxCell id="builder-note" value="Builder Mode Switch&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;enable_builder=True includes snapshot write/delete routes.&lt;br&gt;enable_builder=False exposes read and run routes only.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#6b7280;fontColor=#374151;align=left;spacingLeft=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="445" y="535" width="330" height="105" as="geometry" />
        </mxCell>
        <mxCell id="api-services" value="Service Layer&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;ProtocolService: processes, schemas, snapshots, logs, components&lt;br&gt;RunnerService: start/cancel/report, background execution&lt;br&gt;RunStore: active run, state, events, results&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontColor=#7c2d12;align=left;spacingLeft=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="535" width="705" height="125" as="geometry" />
        </mxCell>

        <mxCell id="api-project" value="Project Directory Data&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;protocols/ for process source and schemas&lt;br&gt;protocols_hystoric/ for snapshots&lt;br&gt;connectivity/associations.json for components&lt;br&gt;log/ and log/archive/ for execution logs&lt;br&gt;log/pool/*.jsonl for live device command polling&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#334155;align=left;spacingLeft=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="735" width="505" height="175" as="geometry" />
        </mxCell>
        <mxCell id="api-execution" value="Execution Path&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;POST /run/ reads a snapshot, validates process configs, creates Platform from connectivity, compiles each Process graph, then WorkflowExecutor emits events for status polling or SSE streaming.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontColor=#4c1d95;align=left;spacingLeft=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="735" width="505" height="120" as="geometry" />
        </mxCell>
